<div class="entry">
   <div class="max-w-2xl mx-auto px-4 py-10">
    <div class="flex justify-between items-center mb-10 border-b border-slate-200 pb-4">
        <h1 class="text-2xl font-black text-slate-900">New Entry</h1>
        <a href="/" class="text-slate-500 hover:text-red-500 transition-colors text-xs uppercase font-bold tracking-widest">
            Cancel
        </a>
    </div>

    <form action="/add-note" method="POST" class="space-y-8">
        
        <div class="flex flex-col gap-3">
            <label for="title" class="text-slate-900 text-lg font-bold tracking-tight">
                Note Title
            </label>
            <input 
                type="text" 
                id="title" 
                name="title" 
                placeholder="What's on your mind?" 
                required
                class="w-full max-w-md bg-white border border-slate-300 rounded-md p-2.5 text-slate-900 text-base focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"
            >
        </div>

        <div class="flex flex-col gap-3">
            <label for="body" class="text-slate-900 text-lg font-bold tracking-tight">
                Content
            </label>
            <textarea 
                id="body" 
                name="body" 
                rows="8" 
                placeholder="Write your entry here..." 
                required
                class="w-full bg-white border border-slate-300 rounded-md p-3 text-slate-800 text-base leading-relaxed focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-none"
            ></textarea>
        </div>

        <div class="pt-2">
            <button 
                type="submit" 
                class="px-8 py-2.5 bg-slate-900 hover:bg-blue-600 text-white font-bold text-sm uppercase tracking-wider rounded-md shadow-sm transition-all active:scale-95"
            >
                Save Entry
            </button>
        </div>
    </form>
</div>
</div>