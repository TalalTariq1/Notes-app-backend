<div class="max-w-4xl mx-auto px-6 py-10">

    <div class="flex justify-between items-center mb-8">

    <a href="/" class="text-[#10b981] hover:text-[#34d399] font-bold text-sm uppercase tracking-wider transition-all mb-8 inline-block">
        ← Back to Vault
    </a>

     <div class="flex gap-6">
            <a href="/edit-note/<%= note._id %>" 
               class="text-blue-500 hover:text-blue-400 font-bold uppercase text-sm transition-all">
               Edit Note
            </a>

            <a href="/delete-note/<%= note._id %>"
               onclick="return confirm('Are you sure you want to delete this note?')"
               class="text-red-500 hover:text-red-400 font-bold uppercase text-sm transition-all">
               Delete Note
            </a>
     </div>

    </div>


    <div class="bg-[#252526] border border-[#3e3e42] rounded-xl p-8 md:p-10 shadow-xl">
        
        <header class="mb-8 border-b border-[#3e3e42] pb-6">
            <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">
                <%= note.title %>
            </h1>
            <p class="text-slate-500 font-mono text-xs uppercase tracking-widest">
                Created: <%= note.createdAt.toDateString() %>
            </p>
        </header>

        <div class="text-[#cccccc] text-base md:text-lg leading-7 whitespace-pre-wrap">
            <%= note.body %>
        </div>

    </div>
</div>

